APP_NAME=A11yPlay API
ENVIRONMENT=development
SECRET_KEY=change-this-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./a11yplay.db
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://a11y-learning.netlify.app
BACKEND_CORS_ORIGIN_REGEX=https://.*\.netlify\.app
FRONTEND_URL=http://localhost:3000
RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_PROVIDER=smtp
EMAIL_FROM=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
GOOGLE_CLIENT_ID=
# Google Custom Search - required for live search in the chatbot.
# Get API key: console.cloud.google.com -> Enable "Custom Search JSON API"
# Get CX (Search Engine ID): programmablesearchengine.google.com
# Free tier: 100 queries/day. Paid: $5 per 1000 queries.
# Without these, all live-fact and current-information questions
# return honest fallback messages instead of hallucinated answers.
GOOGLE_SEARCH_API_KEY=your-google-custom-search-api-key-here
GOOGLE_SEARCH_CX=your-search-engine-id-here
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
