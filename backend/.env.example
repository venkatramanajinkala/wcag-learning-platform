APP_NAME=A11yPlay API
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./a11yplay.db

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_CORS_ORIGIN_REGEX=https://.*\.vercel\.app
FRONTEND_URL=http://localhost:3000

# Password reset
RESET_TOKEN_EXPIRE_MINUTES=30

# Email. Use either Resend or SMTP.
EMAIL_PROVIDER=smtp
EMAIL_FROM=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Google sign-in. Must match frontend VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# Groq LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional live search for current-information chatbot answers.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
